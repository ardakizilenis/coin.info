<!DOCTYPE html>
<html lang="en">
  <%- include("partials/head.ejs") %>
  <body>
    <%- include("partials/navbar.ejs") %>

    <div class="container mt-3">
    
        <h1 class="mb-4">🗞️ Crypto-News</h1>
        <p class="muted mb-4">The newest Headlines from the Crypto World.</p>
        
        
        <form class="sortButtons d-flex gap-3 mb-3" action="/news" method="GET">
            <button type="submit" name="sortBy" value="relevancy" class="btn btn-primary">Most Relevant</button>
            <button type="submit" name="sortBy" value="popularity" class="btn btn-primary">Most Popular</button>
            <button type="submit" name="sortBy" value="publishedAt" class="btn btn-primary">Newest</button>
        </form>

        <main>
            <% 
            const payload   = locals.news ? JSON.parse(locals.news) : {};
            const articles  = (payload && payload.articles) ? payload.articles : [];
            const placeholderImg = "logo.png"; // lege optional ein Platzhalterbild in /public/images ab
            function fmtDate(iso) {
                try { return new Date(iso).toLocaleString(); } catch(e) { return '—'; }
            }
            %>

            <% if (!articles.length) { %>
            <div class="news-empty">
                <h3>No articles found</h3>
                <p class="muted">Try again later!</p>
            </div>
            <% } else { %>

            <section class="news-grid">
                <% articles.forEach(a => { %>
                <article class="news-card">
                    <a class="news-image-wrap" href="<%= a.url ? a.url : "images/logo.png"%>" target="_blank" rel="noopener">
                    <% if (a.urlToImage) { %>
                        <img class="news-image" src="<%= a.urlToImage %>" alt="<%= a.title || 'news image' %>">
                    <% } else { %>
                        <div class="news-image placeholder">
                        <span><%= (a.source && a.source.name) ? a.source.name[0] : 'N' %></span>
                        </div>
                    <% } %>
                    </a>

                    <div class="news-content">
                    <div class="news-topline">
                        <span class="badge source">
                        <%= (a.source && a.source.name) ? a.source.name : 'Unknown Source' %>
                        </span>
                        <% if (a.author) { %>
                        <span class="badge author"><%= a.author %></span>
                        <% } %>
                    </div>

                    <h3 class="news-title">
                        <a href="<%= a.url %>" target="_blank" rel="noopener"><%= a.title || 'Untitled' %></a>
                    </h3>

                    <p class="news-desc">
                        <%= a.description || (a.content ? a.content.split('…')[0] : '') || 'No description available.' %>
                    </p>

                    <div class="news-meta">
                        <time datetime="<%= a.publishedAt || '' %>">
                        <%= a.publishedAt ? fmtDate(a.publishedAt) : '—' %>
                        </time>
                        <a class="read-link" href="<%= a.url %>" target="_blank" rel="noopener">Read →</a>
                    </div>
                    </div>
                </article>
                <% }) %>
            </section>

            <% } %>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
  </body>
</html>
