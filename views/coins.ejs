<!DOCTYPE html>
<html lang="en">
<%- include("partials/head.ejs") %>
<body>
    <%- include("partials/navbar.ejs") %>

    <div class="container">
        <div class="coinsSearchBar mt-5">
            <input class="form-control me-2 search-input-coins" type="search" name="" id="" placeholder="🔍 Search for Name or UUID...">
            <button class="btn btn-outline-primary search-button-coins" type="submit">Search</button>
        </div>
        <table class="table table-striped mt-5">
            <thead>
                <tr>
                    <th scope="col">Icon</th>
                    <th scope="col">Coin</th>
                    <th scope="col">Name</th>
                    <th scope="col">Price</th>
                    <th scope="col">24h</th>
                    <th scope="col">Market Cap</th>
                    <th scope="col">Volume</th>
                </tr>
            </thead>
            <tbody>
                <% if (locals.coinlist) { %>
                    <% const coinList = JSON.parse(locals.coinlist) %>
                    <% for(let i = 0; i<coinList.length; i++) {%>
                        <tr>
                            <td><img src=<%= coinList[i].iconUrl%> alt="icon" style="width: 20px;" ></th>
                            <td><%= coinList[i].symbol %></td>
                            <td><%= coinList[i].name %></td>
                            <td><%= Intl.NumberFormat('en-US').format(parseFloat(coinList[i].price).toFixed(2)) %>$</td>
                            <% if(parseFloat(coinList[i].change) < 0) { %>
                                <td class="negative"><%= parseFloat(coinList[i].change)%>%</td>
                            <% } else if(parseFloat(coinList[i].change) > 0) { %>
                                <td class="positive"><%= parseFloat(coinList[i].change)%>%</td>
                            <% } else { %>
                                <td><%= parseFloat(coinList[i].change)%>%</td>
                            <% } %>
                            <td><%= Intl.NumberFormat('en-US').format(parseFloat(coinList[i].marketCap)) %>$</td>
                            <td><%= Intl.NumberFormat('en-US').format(parseFloat(coinList[i]['24hVolume'])) %></td>
                        </tr>
                    <% }; %>
                <% } %>
            </tbody>
        </table>
    </div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>        
</body>
</html>