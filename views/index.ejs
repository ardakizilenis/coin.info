<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Coin.info</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="/style/style.css">
</head>
<body>
    
    <header>
        <nav class="navbar navbar-expand-md fixed-top"> 
            <div class="container-fluid"> 
                <a class="navbar-brand pt-0" href="#"><img class="logo" src="/images/logo.png" alt="logo"></a> 
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse" aria-controls="navbarCollapse" aria-expanded="false" aria-label="Toggle navigation"> 
                    <span class="navbar-toggler-icon"></span> 
                </button>
                <div class="collapse navbar-collapse nav__links" id="navbarCollapse"> 
                    <ul class="navbar-nav me-auto mb-2 mb-md-0"> 
                        <li class="nav-item"> 
                            <a class="nav-link active" href="#">Home</a> 
                        </li> 
                        <li class="nav-item"> 
                            <a class="nav-link" href="#">Coins</a> 
                        </li> 
                        <li class="nav-item"> 
                            <a class="nav-link" href="#">Markets</a> 
                        </li>
                        <li class="nav-item"> 
                            <a class="nav-link" href="#">About</a> 
                        </li> 
                    </ul> 
                </div> 
            </div> 
        </nav>
    </header>

    <div class="px-0 py-5 my-2 text-center d-flex flex-column justif-content-between homeHero"> 
        <h1 class="display-1 fw-bold text-body-emphasis fade-in-down">
            <span class="line line1">All Crypto Tokens.</span><br>
            <span class="line line2">On One Place.</span>
        </h1>
        <div class="col-lg-6 mx-auto mb-3 fade-in-down"> 
            <p class="lead my-3 d-flex flex-column justify-content-center align-items-center">
                <span class="line line3">View Live Prices, Market Data, Charts and Trends</span>
                <span class="line line4">- powered by Coinranking.</span>
            </p>
        </div>
        <div class="cta-buttons container mx-auto">
            <div class="heroSearchBar mt-3">
                <input class="form-control me-2 search-input-hero" type="search" name="" id="" placeholder="🔍 Search for Bitcoin, Ethereum, Dogecoin…">
                <button class="btn btn-outline-primary search-button-hero" type="submit">Search</button>
            </div>
            <div class="topcoins d-flex flex-column">
                <button type="submit" class="viewTop50 btn btn-primary my-2">View The Top 50</button>
                <button type="submit" class="trending btn btn-outline-primary">Trending Coins Today</button>
            </div>
        </div>
        
    </div>
 
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>    
</body>
</html>