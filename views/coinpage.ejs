<!DOCTYPE html>
<html lang="en">
<%- include("partials/head.ejs") %>
<body>
    <%- include("partials/navbar.ejs") %>
    <% const coin = JSON.parse(locals.coin); %>
    <!-- views/coinpage.ejs -->
     <div class="container">
        <section class="coin-hero">
        <div class="coin-id">
            <img src="<%= coin.iconUrl %>" alt="<%= coin.name %> icon" class="coin-icon">
            <div>
                <h1><%= coin.name %> <span class="sym">(<%= coin.symbol %>)</span></h1>
                <div class="sub">
                    <span class="rank">Rank #<%= coin.rank %></span>
                    <span class="tag" style="background:<%= coin.color || '#eee' %>20;color:<%= coin.color || '#333' %>">Core</span>
                </div>
            </div>
            
        </div>
        <div class="price-block">
            <div class="price">
            <%= Intl.NumberFormat('en-US', {maximumFractionDigits: 2}).format(parseFloat(coin.price)) %>$ 
            </div>
            <div class="change <%= parseFloat(coin.change) >= 0 ? 'pos' : 'neg' %>">
            <%= parseFloat(coin.change) %>%
            </div>
        </div>
        </section>

        <section class="quick-links">
        <% const linkByType = (t)=> coin.links.find(l => l.type===t); %>
        <% const links = [
            linkByType('website') || {name:'Website', url: coin.websiteUrl},
            linkByType('explorer'),
            linkByType('github'),
            linkByType('reddit'),
            coin.links.find(l=>l.type==='whitepaper'),
            linkByType('cmc')
            ].filter(Boolean); %>
        <% links.forEach(l => { %>
            <a class="chip" href="<%= l.url %>" target="_blank" rel="noopener"><%= l.type %></a>
        <% }) %>
        </section>

        <section class="metrics-grid">
        <div class="metric">
            <span>M. Cap</span>
            <strong><%= Intl.NumberFormat('en-US').format(parseFloat(coin.marketCap)) %>$</strong>
        </div>
        <div class="metric">
            <span>FDV</span>
            <strong><%= Intl.NumberFormat('en-US').format(parseFloat(coin.fullyDilutedMarketCap)) %>$</strong>
        </div>
        <div class="metric">
            <span>24h Volume</span>
            <strong><%= Intl.NumberFormat('en-US').format(parseFloat(coin['24hVolume'])) %></strong>
        </div>
        <div class="metric">
            <span>Markets / Exchanges</span>
            <strong><%= coin.numberOfMarkets %> / <%= coin.numberOfExchanges %></strong>
        </div>
        <div class="metric">
            <span>BTC Price</span>
            <strong><%= coin.btcPrice %> BTC</strong>
        </div>
        <div class="metric">
            <span>Listed</span>
            <strong><%= new Date(coin.listedAt*1000).toLocaleDateString() %></strong>
        </div>
        </section>

        <section class="supply-ath">
        <div class="supply">
            <% const max = parseFloat(coin.supply.max || 0); 
            const circ = parseFloat(coin.supply.circulating || 0);
            const pct = max ? Math.min(100, (circ/max)*100) : 0; %>
            <div class="supply-head">
            <span>Circulating</span>
            <span><%= Intl.NumberFormat('en-US').format(circ) %> / 
                    <%= max ? Intl.NumberFormat('en-US').format(max) : '—' %></span>
            </div>
            <div class="bar"><span style="width:<%= pct %>%"></span></div>
        </div>

        <div class="ath">
            <div>All-Time High</div>
            <strong>
            <%= Intl.NumberFormat('en-US', {maximumFractionDigits:2}).format(parseFloat(coin.allTimeHigh.price)) %>$
            </strong>
            <small><%= new Date(coin.allTimeHigh.timestamp*1000).toLocaleDateString() %></small>
        </div>
        </section>

        <section class="chart">
        <div id="spark" data-points='<%- JSON.stringify(coin.sparkline.map(Number)) %>'></div>
        </section>

        <section class="description">
        <p id="desc"><%= coin.description %></p>
        <button id="toggleDesc" class="linklike">Mehr anzeigen</button>
        </section>

        <section class="tags">
        <% (coin.tags || []).forEach(t => { %>
            <span class="tag-soft"><%= t %></span>
        <% }) %>
        </section>        
     </div>

    
    <script>
    // Minimal Sparkline (ohne Library)
    (function(){
        const el = document.getElementById('spark');
        const data = JSON.parse(el.dataset.points || '[]');
        if (!data.length) return;
        const w = el.clientWidth || 600, h = 120, p=8;
        const min = Math.min(...data), max = Math.max(...data);
        const x = i => p + i*( (w-2*p)/(data.length-1) );
        const y = v => h - p - ( (v-min)/(max-min || 1) )*(h-2*p);

        let d = `M ${x(0)} ${y(data[0])}`;
        for (let i=1;i<data.length;i++) d += ` L ${x(i)} ${y(data[i])}`;

        el.innerHTML = `
        <svg width="100%" height="${h}" viewBox="0 0 ${w} ${h}" preserveAspectRatio="none">
            <path d="${d}" fill="none" stroke="currentColor" stroke-width="2"/>
        </svg>`;
    })();

    // Beschreibung toggeln
    (function(){
        const btn = document.getElementById('toggleDesc');
        const p = document.getElementById('desc');
        if (!btn || !p) return;
        const limit = 280;
        const full = p.textContent;
        if (full.length <= limit) { btn.style.display='none'; return; }
        p.dataset.full = full;
        p.textContent = full.slice(0, limit) + '…';
        let open = false;
        btn.addEventListener('click', () => {
        open = !open;
        p.textContent = open ? p.dataset.full : (p.dataset.full.slice(0,limit)+'…');
        btn.textContent = open ? 'Weniger anzeigen' : 'Mehr anzeigen';
        });
    })();
    </script>

</body>
</html>